# ============================================================
# auth-service environment configuration template
# Copy to .env (local dev) or supply as secrets in staging/prod
# ============================================================

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://testuser:testpass@postgres:5432/testdatabase

# ── OAuth Providers ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

REDIRECT_URI=http://localhost:8000
FRONTEND_URL=http://localhost:8080

# ── Internal service key ─────────────────────────────────────
INTERNAL_SERVICE_KEY=change-me-use-a-long-random-secret

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Email ────────────────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# ── CORS (required for staging/prod) ─────────────────────────
# Explicit list of allowed browser origins — JSON array format.
# NEVER use ["*"] with allow_credentials=True (rejected by browsers).
#
# Dev default (already set in config.py):
#   ALLOWED_ORIGINS=["http://localhost:8080"]
#
# Staging / production — set via secrets manager or CI env:
#   ALLOWED_ORIGINS=["https://app.oraclous.com","https://studio.oraclous.com"]
#
ALLOWED_ORIGINS=["http://localhost:8080"]

# ── Trusted proxy IPs (required for staging/prod) ────────────
# IPs or CIDRs of trusted reverse proxies (ALB / nginx).
# ProxyHeadersMiddleware rewrites request.client to the real
# X-Forwarded-For IP only when the direct connection comes from
# one of these addresses, preventing XFF spoofing.
#
# Dev default (loopback, safe for local dev):
#   TRUSTED_PROXY_IPS=["127.0.0.1"]
#
# Staging / production — replace with your ALB internal IP/CIDR:
#   TRUSTED_PROXY_IPS=["10.0.0.0/8"]           # private VPC range
#   TRUSTED_PROXY_IPS=["10.0.1.42"]             # single ALB IP
#   TRUSTED_PROXY_IPS=["10.0.1.0/24"]           # ALB subnet CIDR
#
# ⚠️  Do NOT set ["*"] here — it disables XFF spoofing protection.
#
TRUSTED_PROXY_IPS=["127.0.0.1"]
